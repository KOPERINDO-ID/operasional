<?xml version='1.0' encoding='utf-8'?>
<widget id="io.cordova.operasional_tasindo" version="1.0.0" xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Admin</name>
    <description>
        Admin
    </description>
    <author email="vertice15@gmail.com" href="https://vertice.id">
        Vertice Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- Android Build Settings -->
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="android-compileSdkVersion" value="34" />

    <!-- Gradle Settings -->
    <preference name="AndroidXEnabled" value="true" />
    <preference name="GradlePluginGoogleServicesEnabled" value="true" />
    <preference name="GradlePluginGoogleServicesVersion" value="4.4.1" />

    <platform name="android">
        <plugin name="cordova-plugin-camera" spec="./plugins/cordova-plugin-camera">
            <variable name="ANDROID_SUPPORT_V4_VERSION" value="27.+" />
        </plugin>
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="icon.png" />
        <allow-intent href="market:*" />
        <icon density="hdpi" src="icon.png" />
        <preference name="Orientation" value="portrait" />
        <preference name="AutoHideSplashScreen" value="true" />
        <preference name="SplashScreenDelay" value="2500" />
        <preference name="SplashMaintainAspectRatio" value="true" />
        <preference name="SplashShowOnlyFirstTime" value="true" />
        <preference name="ShowSplashScreenSpinner" value="false" />
        <preference name="SplashScreenBackgroundColor" value="white" />
        <preference name="StatusBarBackgroundColor" value="#63714d" />
        <preference name="AndroidPersistentFileLocation" value="Internal" />
        <preference name="iosExtraFilesystems"
            value="library,library-nosync,documents,documents-nosync,cache,bundle,root" />
        <preference name="AndroidExtraFilesystems"
            value="files,files-external,documents,sdcard,cache,cache-external,assets,root" />

        <resource-file src="google-services.json" target="app/google-services.json" />
        <preference name="AndroidLaunchMode" value="singleTop" />

        <!-- PENTING: Set versi Gradle dan AGP yang kompatibel -->
        <preference name="GradleVersion" value="8.2" />
        <preference name="AndroidGradlePluginVersion" value="8.2.0" />
    </platform>

    <plugin name="cordova-plugin-statusbar" spec="^3.0.0" />
    <engine name="browser" spec="^6.0.0" />
</widget>